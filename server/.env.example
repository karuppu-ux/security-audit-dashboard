# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Leave MONGODB_URI empty in development to spin up an in-process MongoDB
# (mongodb-memory-server) automatically — no install required. Set it to a real
# connection string for Docker / Atlas / production.
#
#   Docker compose : mongodb://mongo:27017/audit_logs
#   Local install  : mongodb://127.0.0.1:27017/audit_logs
#   Atlas          : mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/audit_logs
MONGODB_URI=
MONGODB_DB_NAME=audit_logs

# ---------------------------------------------------------------------------
# Ingest limits
# ---------------------------------------------------------------------------
# Max records accepted in a single POST /api/v1/logs/bulk request.
MAX_BULK_RECORDS=20000
# Max raw JSON body size. 10k records is ~2.5MB; this leaves generous headroom.
JSON_BODY_LIMIT=25mb
# Records per insertMany() call at the database layer.
BULK_BATCH_SIZE=1000

# ---------------------------------------------------------------------------
# Query limits
# ---------------------------------------------------------------------------
# Max page size a client may request on GET /api/v1/logs.
MAX_PAGE_SIZE=100
# Abort counts/queries that exceed this many milliseconds.
QUERY_TIMEOUT_MS=5000
