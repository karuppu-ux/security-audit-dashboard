# Base URL of the API.
#
# Leave empty for local development: Vite proxies /api and /health to
# http://localhost:4000 (see vite.config.js), so the browser sees a same-origin
# API and CORS never comes into play.
#
# Set it for a deployed frontend talking to a separately-hosted API, e.g.
#   VITE_API_BASE_URL=https://audit-log-api.onrender.com
VITE_API_BASE_URL=
